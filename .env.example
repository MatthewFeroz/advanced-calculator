# Copy this file to `.env` and adjust the values to configure the calculator.

# Where log files and history files are stored (defaults live inside the project).
# CALCULATOR_LOG_DIR=logs
# CALCULATOR_HISTORY_DIR=history

# How many calculations to keep in history before old ones are dropped.
CALCULATOR_MAX_HISTORY_SIZE=100

# Automatically save history to CSV after every calculation (true/false).
CALCULATOR_AUTO_SAVE=true

# How many decimal places results are rounded to.
CALCULATOR_PRECISION=10

# The largest number the calculator will accept as input.
CALCULATOR_MAX_INPUT_VALUE=1e999

# Text encoding used when reading and writing files.
CALCULATOR_DEFAULT_ENCODING=utf-8
